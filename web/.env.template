# NovaMind AI Frontend Environment Variables
# Copy this file to .env.local and fill in the values

# Backend root URL the browser talks to. NO trailing /api/v1.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Set to 'true' to use an in-browser mock backend (localStorage).
# Set to 'false' (or remove) once a real FastAPI backend is deployed.
NEXT_PUBLIC_USE_MOCK=false