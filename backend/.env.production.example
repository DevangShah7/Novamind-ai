# NovaMind AI Backend - Production Environment Variables
# Copy to /opt/novamind/.env on the server, then `chmod 600`.

# --- REQUIRED ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-me-with-secrets-token-urlsafe-64

# SQLite database file (lives in /opt/novamind/novamind.db on the VM).
# To use Postgres instead: DATABASE_URL=postgresql://user:pass@localhost:5432/novamind
DATABASE_URL=sqlite:///./novamind.db

# --- OPTIONAL (have safe defaults) ---
# Allow Vercel frontend + your local browser.
BACKEND_CORS_ORIGINS=https://web-ivory-eta-87.vercel.app,http://localhost:3000

# Google OAuth — leave blank to disable social login (email/password still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Redis / ChromaDB — left unset means the in-memory shim is used (fine for free tier).
# REDIS_URL=redis://localhost:6379
# CHROMA_HOST=localhost
# CHROMA_PORT=8000